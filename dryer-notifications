alias: Dryer Complete - Notification
description: Sends notification when dryer finishes
triggers:
  - trigger: state
    entity_id:
      - binary_sensor.dryer_run_completed
    to:
      - "on"
    from:
      - "off"
conditions: []
actions:
  - choose:
      - conditions:
          - condition: state
            entity_id: person.michael
            state:
              - home
          - condition: state
            entity_id: person.queen_supreme
            state:
              - home
        sequence:
          - action: notify.mobile_app_michaels_iphone
            data:
              title: Dryer Complete
              message: Please remove laundry
              data:
                tag: dryer-complete-notification
            continue_on_error: true
          - action: notify.mobile_app_rachels_iphone
            data:
              title: Dryer Complete
              message: Please remove laundry
              data:
                tag: dryer-complete-notification
            continue_on_error: true
        alias: If both home
      - conditions:
          - condition: state
            entity_id: person.michael
            state:
              - home
          - condition: state
            entity_id: person.queen_supreme
            state:
              - not_home
        sequence:
          - action: notify.mobile_app_michaels_iphone
            data:
              title: Dryer Complete
              message: Please remove laundry
              data:
                tag: dryer-complete-notification
            continue_on_error: true
        alias: Michael Home
      - conditions:
          - condition: state
            entity_id: person.queen_supreme
            state:
              - home
          - condition: state
            entity_id: person.michael
            state:
              - not_home
        sequence:
          - action: notify.mobile_app_rachels_iphone
            data:
              title: Dryer Complete
              message: Please remove laundry
              data:
                tag: dryer-complete-notification
            continue_on_error: true
        alias: Rachel Home
    default:
      - stop: No one home
    continue_on_error: true
mode: single
